    sta GU_toP+1                           

    ldx GU_toY                  
    lda x320_lo,x                          
    clc                                    
    adc GU_toP               
    sta GU_toP                             
    lda x320_hi,x                          
    adc GU_toP+1                            
    sta GU_toP+1                           

	lda GU_tile_color           
