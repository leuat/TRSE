//{---------------------------------------------------- LoadFile ---------------------------------------------------- 
procedure LoadFile(fileName : global ^byte, addr : global integer);
begin
	fp := #fileName;
	len := str::strlen(#fileName);

	PageSysRam();

	asm("
				 lda GU_len
			     ldx GU_fp
			     ldy GU_fp+1
			     jsr $ffbd    		;//call setnam
			     ldx #$08      		;// default to device 8
				 ldy #$00      		;// $00 means: load to new address
			     jsr $ffba    		;// call setlfs
			     ldx GU_addr
			     ldy GU_addr+1
			     lda #$00      		;// $00 means: load to memory (not verify)
			     jsr $ffd5      	;// call load
	");

	PageFullRam();
end;

end. 
