	sta GU_fromP               
	stx GU_fromP+1
	lda GU_screen_loc           
	ldx GU_screen_loc+1
	sta GU_toP                  
	stx GU_toP+1

tmpvar1 = $54                                     
    lda #$00                                 
    sta tmpvar1                            
    lda GU_fromX  
    asl                                   
    asl                                   
    asl                                   
    rol tmpvar1                             
    adc GU_fromP                            
    sta GU_fromP                          
    lda tmpvar1                            
    adc GU_fromP+1                         
    sta GU_fromP+1                          

	ldx GU_fromY           
    lda x320_lo,x                           
    clc                                     
    adc GU_fromP                
    sta GU_fromP                            
    lda x320_hi,x                          
    adc GU_fromP+1                         
    sta GU_fromP+1                         

tmpvar2 = $54                                       
    lda #00                                 
    sta tmpvar2                             
    lda GU_toX     
    asl                                   
    asl                                   
    asl                                   
    rol tmpvar2                             
    adc GU_toP                              
