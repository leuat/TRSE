	sta GU_fromCP+0
	bcc GU_DrawPic_WordAdd268
	inc GU_fromCP+1
GU_DrawPic_WordAdd268

	ldx GU_fromY   ;	ldy #0                      
    lda x40_lo,x                         
    clc                                    
    adc GU_fromCP                          
    sta GU_fromCP                          
    lda x40_hi,x                           
    adc GU_fromCP+1                        
    sta GU_fromCP+1                      

	lda GU_toCP                 
	clc
	adc GU_toX
	sta GU_toCP+0
	bcc GU_DrawPic_WordAdd272
	inc GU_toCP+1
GU_DrawPic_WordAdd272

    ldx GU_toY     ;	ldy #0                      
    lda x40_lo,x                         
    clc                                    
    adc GU_toCP                             
    sta GU_toCP                            
    lda x40_hi,x                           
