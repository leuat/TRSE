	lda GU_fromCP                          
    sta GU_fromCP2+0                        
    clc                                    
    lda GU_fromCP+1                         
    adc #$04                               
    sta GU_fromCP2+1                       
                                            
    lda GU_toCP                                         
    sta GU_toCP2+0                         
    clc                                     
    lda GU_toCP+1                          
    adc #$04                               
    sta GU_toCP2+1                          
                                            
	lda GU_lenX    
	asl
	asl
	asl
	sta GU_lenX8
	lda #$0                     

	sta GU_i
GU_DrawPic_forloop278
	ldy GU_lenX
	dey
GU_DrawPic_memcpy292
	lda (GU_fromCP),y           
	sta (GU_toCP),y
	dey
	bpl GU_DrawPic_memcpy292
	ldy GU_lenX
	dey
GU_DrawPic_memcpy293
	lda (GU_fromCP2),y          
	sta (GU_toCP2),y
	dey
	bpl GU_DrawPic_memcpy293
	ldy GU_lenX8
	dey
GU_DrawPic_memcpy294           
	lda (GU_fromP),y            
	sta (GU_toP),y              
	dey
	bpl GU_DrawPic_memcpy294
	lda GU_fromP                
	clc
	adc #$40
	sta GU_fromP+0             
	lda GU_fromP+1
	adc #$01
	sta GU_fromP+1              
	lda GU_toP                 
	clc
	adc #$40
