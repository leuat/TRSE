Unit GU;

@use "system/str"

var	
	const JOY_UP : byte = 1;
	const JOY_DOWN : byte = 2;
	const JOY_LEFT : byte = 4;
	const JOY_RIGHT : byte = 8;
	const JOY_FIRE : byte = 64;
	const JOY2_FIRE : byte = 128;
	
	const MODE_HIRES : byte = 0;
	const MODE_MULTICOLOR : byte = 1;
	
	const MUSIC_NORMAL : byte = 0;
	const MUSIC_DOUBLE : byte = 1;

	fromX, fromY, toX, toY, lenX, lenY : byte;
	
	joys 	: byte;
	joyv 	: byte;
	musicon	: byte=0;
	musicpause	: byte=1;
	digion	: byte=0;
	i,j		: byte;
	charsetAddress : integer;
	iint:integer;
	
	
	m0,m1,m2,m3 : pointer of integer;
	g0,g1,g2 : integer;
	loc: integer;
	
	fromP, toP, fromCP, toCP, fromCP2, toCP2	: pointer;
	tile_data, tile_color : integer;
	screen_loc, color_loc : integer;
	color_data : integer;
	
	fp : pointer;
	len : byte;
	addr, addr2 : integer;	jc0, jc1, jc2 : byte;
	qs0, qs1, qs2 : byte;
	jrem : byte;	maskb, coltmp, vstep : byte;
	
	toprint: array[6] of byte;
	fileName : ^byte;
	
	lenX8: byte;
	
	
	tmp_lo, tmp_hi, off_lo, off_hi : byte;
	line : byte;
	

//{---------------------------------------------------- Sync ---------------------------------------------------- 
procedure Sync(line : global byte);
begin
asm("
	LDA GU_line
	CMP $FF1D
	BNE *-3
	");
end;

//{------------------------- WaitSync --------------------------------
procedure WaitSync(sec: byte);
var w:byte;
begin

	if sec >0 then
	for w:=0 to sec do
		Sync($BE);
end;

//{---------------------------------------------------- InitDigi ---------------------------------------------------- 
procedure InitDigiAndMusic();
begin
	asm("
		jmp play_init	
		
playirq 
		pha
		txa
		pha
		tya
		pha					; push accumulator

	    lda $ff09          
		and #$08
		beq music_timer
		
		lda GU_digion
		beq pend	
buf		EQU *+1				; write buf, self modifying code
		lda #0
		sta $ff11			; write to D/A
playptr EQU *+1				; sample play pointer, self mod.
		lda $1200
		cmp #$F1				; if magic number,
		beq penda			; exit
		clc
		adc #$b1				; map sample to $B1..$B8
		sta buf				; store in write buf
		inc playptr			; increment play pointer
		bne pend
		inc playptr+1
pend		
		lda #$08
		sta $ff09			; ack timer irq
		jmp endirq
penda
		lda #$0
		sta GU_digion
		lda #$1
		sta GU_musicpause
		sta $FD
		jmp endirq

dummy	DC.B $F1 

music_timer
		lda $ff09          
		and #$10
		beq endirq
		lda #$10
		sta $ff09			; ack timer 2

		lda GU_musicpause
		beq nextirq
		lda GU_musicon
		beq nextirq
		jsr GU_PlayMusic
nextirq
		jsr mustimnorm
endirq
		pla
		tay
		pla
		tax
		pla

		rti

GU_PlayMusic
	jmp (GU_m1)
	

play_init
		sei
		sta $ff3f		; switch to full ram config
		lda #<playirq
		sta $fffe
		lda #>playirq
		sta $ffff
		lda #$DE			; set timer 4khz ($94 6khz $6F 8khz)
		sta $ff00
		lda #$00
		sta $ff01
minit	jsr mustimnorm
		lda #$18			; set irq masks
		sta $ff0a
		lda #0			; init write buffer
		sta buf
		lda #<dummy		; init sample play pointer
		sta playptr		; to point to dummy
		lda #>dummy		; (which contains the end-sample magic number)
		sta playptr+1		
		inc $ff09		; delete pending irq's
		cli				; enable irq's
		rts
		
mustimnorm	
		lda #$c8			; set timer normal
		sta $ff02
		lda #$38
		sta $ff03
		rts
		
mustimdub	 
		lda #$a3			; set timer double
		sta $ff02
		lda #$22
		sta $ff03
		rts	
	");
	
end;

//{---------------------------------------------------- PlayDigi ----------------------------------------------------
procedure PlayDigi(sample : integer);
begin
	poke(^$FD,0,1);
	digion:=1;
	musicpause:=0;
	
	_a:=lo(sample);
	_x:=hi(sample);

	asm("
 		php
		sei
		sta playptr			; update sample play pointer
		stx playptr+1
		plp					; restore irq flag
		rts
	");
	
end;

//{---------------------------------------------------- GetJoy ---------------------------------------------------- 
function GetJoy(joy: byte) : byte;
begin
	joys:=$fb;
	if joy=2 then joys:=$fd;

    asm("
	  lda #$ff
	  sta $fd30
	  lda GU_joys
	  sta $ff08
	  lda $ff08;keep
	  STA GU_joyv 
      ");
      
      GetJoy:=joyv;
end;

//{---------------------------------------------------- StartMusic ---------------------------------------------------- 
procedure StartMusic(gameMusic : integer, mnumber : byte, mode : byte);
begin
	
	if mode=MUSIC_DOUBLE then
	asm("
		lda #<mustimdub
		sta nextirq+1
		sta minit+1
		lda #>mustimdub
		sta nextirq+2
		sta minit+2
	");	
	
	g0:=gameMusic+2;
	g1:=mnumber;
	musicon:=1;
	
	asm("
		lda GU_g0
		ldx GU_g0+1
		sta GU_m0
		stx GU_m0+1

		LDA GU_g1
	");

	Call(m0);

	g1:=gameMusic+5;
	
	asm("
		lda GU_g1
		ldx GU_g1+1
		sta GU_m1
		stx GU_m1+1
	");
end;

//{---------------------------------------------------- StopMusic ---------------------------------------------------- 
procedure StopMusic();
begin
	poke(^$ff11,0,0);
	musicon:=0;
end;

//{---------------------------------------------------- PageFullRam ---------------------------------------------------- 
procedure PageFullRam();
begin
	poke(^$FF3F,0,1);
end;

//{---------------------------------------------------- PageSysRam ---------------------------------------------------- 
procedure PageSysRam ();
begin
	poke(^$FF3E,0,1);
end;

//{---------------------------------------------------- SetBitmapMode ---------------------------------------------------- 
procedure SetBitmapMode();
begin
asm("
	lda $ff06
	ora #$20
	sta $ff06
");
end;

//{---------------------------------------------------- TurnOnScreen ---------------------------------------------------- 
procedure TurnOnScreen();
begin
asm("
	lda #$3b
	sta $ff06
");
end;

//{---------------------------------------------------- TurnOnScreen ---------------------------------------------------- 
procedure TurnOffScreen();
begin
asm("
	lda $ff06
	and #$ef
	sta $ff06
");
end;

//{---------------------------------------------------- SetMulticolorMode ---------------------------------------------------- 
procedure SetMulticolorMode();
begin
asm("
	lda $ff07	
	ora #$10
	sta $ff07
	");
end;

//{---------------------------------------------------- SetHiresMode ---------------------------------------------------- 
procedure SetHiresMode();
begin
asm("
	lda $ff07	
	and #$ef
	sta $ff07
	");
end;

//{---------------------------------------------------- SetSharedColor ---------------------------------------------------- 
procedure SetSharedColorsByData(color_data : global integer);
begin
	asm("
		lda GU_color_data
		clc
		adc #$fe
		sta GU_fromP
		lda GU_color_data+1
		adc #$03
		sta GU_fromP+1

		ldy #$00
		lda (GU_fromP),y
		tax
		and #$0f
		asl
		asl
		asl
		asl
		sta GU_coltmp
		txa
		and #$f0
		lsr
		lsr
		lsr
		lsr
		ora GU_coltmp
		sta $ff16

		iny
		lda (GU_fromP),y
		tax
		and #$0f
		asl
		asl
		asl
		asl
		sta GU_coltmp
		txa
		and #$f0
		lsr
		lsr
		lsr
		lsr
		ora GU_coltmp
		sta $ff15
	");
end;

//{---------------------------------------------------- SetSharedColor ---------------------------------------------------- 
procedure SetSharedColor(color : byte);
begin
	poke(^$FF16,0,color);
end;

//{---------------------------------------------------- SetScreenLoc ---------------------------------------------------- 
procedure SetScreenLoc(loc : global integer);
begin
	poke(^$FF12,0,loc/1024);
end;

//{---------------------------------------------------- SetColorLoc ---------------------------------------------------- 
procedure SetColorLoc(loc: global  integer);
begin
	loc:=loc/2048;
	loc:=(loc)<<3;
	asm("
		lda $FF14 
		and #%00000111
		ora GU_loc
		sta $FF14 
	");
	
end;

//{---------------------------------------------------- RandomNumber ---------------------------------------------------- 
function RandomNumber(maxNumber:byte) : byte;
var 
	ran:integer;
begin 
	ran:=Random()*maxNumber;
	ran:=ran/256;
	RandomNumber := ran;
end; 

//{---------------------------------------------------- DrawChar ---------------------------------------------------- 
procedure DrawChar(xch:byte, ych:byte, ascii: byte, colorch: byte);
begin
	fromP:=charsetAddress+ascii*8;
	toP:=screen_loc+xch*8;

	if ych>0 then for i:=0 to ych do toP+=320;

	MemCpyUnroll(fromP, 0, toP,8);
	
	toP:=color_loc+xch+ych*40;
	fromP:=toP+1024;
	
	Poke(toP,0,colorch);
	Poke(fromP,0,colorch);
	
end;

//{---------------------------------------------------- DrawString ---------------------------------------------------- 
procedure DrawString(xs:integer, ys:byte, text:^byte, colors: byte);
var char: byte;
begin
	iint:=0;
	
	while(text[iint]>0) do
	begin
		char:=text[iint];
		if(char>64) then char:=char-64;
		DrawChar(iint+xs, ys, char, colors);
		iint:=iint+1;
	end;
end;

//{---------------------------------------------------- DrawNumber ---------------------------------------------------- 
procedure DrawNumber(xn:integer, yn:byte, number:Integer, colorn:byte);
begin
	str::itoa(number, #toprint, 10);
	
	DrawString(xn, yn, #toprint, colorn);
end;

//{---------------------------------------------------- InitGameUnit ---------------------------------------------------- 
procedure InitGameUnit(screenL, colorL, tiledata, tilecolor, charset : integer, mode : byte);
begin
	screen_loc := screenL;
	color_loc := colorL;
	tile_data := tiledata;
	tile_color := tilecolor;
	charsetAddress := charset;
	SetScreenLoc(screen_loc);
	SetColorLoc(color_loc);
	
	GU::TurnOnScreen();
	GU::SetBitmapMode();	
	if mode = MODE_MULTICOLOR then GU::SetMulticolorMode();	
	GU::PageFullRam();
	PreventIRQ();
	DisableCIAInterrupts();
end;

//{---------------------------------------------------- ClearScreen ---------------------------------------------------- 
procedure CLS();
begin
	toP:=screen_loc;
	toCP:=color_loc;

	for i:=0 to 32 do
	begin
		Fill(toP, 0, 255);
		toP+=255;
		Fill(toCP, 0, 64);
		toCP+=64;
	end;
	
end;

